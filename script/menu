#!/usr/bin/env bash

if ps -a | grep wofi >/dev/null; then
  killall -q wofi
else
  case $(printf "%s\n" "¾░Éź p: POWER OFF" "¾░æÉ r: RESTART" "¾░¢ö s: SUSPEND" "¾░īŠ l: LOCK" "¾░ŚĮ o: LOG OUT" | wofi --show=dmenu --hide-scroll --allow-markup --define=hide_search --width=600 --height=200) in
  "¾░Éź p: POWER OFF")
    systemctl poweroff
    ;;
  "¾░æÉ r: RESTART")
    systemctl reboot
    ;;
  "¾░¢ö s: SUSPEND")
    systemctl suspend
    ;;
  "¾░īŠ l: LOCK")
    swaylock
    ;;
  "¾░ŚĮ o: LOG OUT")
    hyprctl dispatch exit 1
    ;;
  esac
fi
