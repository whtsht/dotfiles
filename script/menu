#!/usr/bin/env bash

if (ps -a | grep wofi >/dev/null); then
  killall -q wofi
else
  case $(printf "%s\n" "¾░Éź Power Off" "¾░æÉ Restart" "¾░¢ö Suspend" "¾░īŠ Lock" "¾░ŚĮ Log Out" | wofi --show=dmenu --hide-scroll --allow-markup --define=hide_search --width=600 --height=200) in
  "¾░Éź Power Off")
    systemctl poweroff
    ;;
  "¾░æÉ Restart")
    systemctl reboot
    ;;
  "¾░¢ö Suspend")
    systemctl suspend
    ;;
  "¾░īŠ Lock")
    swaylock
    ;;
  "¾░ŚĮ Log Out")
    hyprctl dispatch exit 1
    ;;
  esac
fi
